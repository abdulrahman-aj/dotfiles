// Zed keymap
//
// For information on binding keys, see the Zed
// documentation: https://zed.dev/docs/key-bindings
//
// To see the default key bindings run `zed: open default keymap`
// from the command palette.
[
  {
    "context": "Pane",
    "bindings": {
      "ctrl-shift-tab": "pane::ActivatePreviousItem",
      "ctrl-tab": "pane::ActivateNextItem",
    },
  },
  {
    "context": "EmptyPane || MarkdownPreview || (ProjectPanel || AgentPanel) && not_editing || (Editor && vim_mode == normal)",
    "bindings": {
      "space space": "file_finder::Toggle",
      "space b o": ["pane::CloseOtherItems", { "close_pinned": false }],
      "space g g": ["task::Spawn", { "task_name": "lazygit" }],
      "space d": ["task::Spawn", { "task_name": "lazydocker" }],
      "space o c": ["task::Spawn", { "task_name": "opencode" }],
      "space e": "project_panel::Toggle",
      "space a": "agent::Toggle",
    },
  },
  {
    "context": "vim_mode == visual",
    "bindings": {
      "p": ["vim::Paste", { "preserve_clipboard": true }],
    },
  },
  {
    "context": "MarkdownPreview",
    "bindings": {
      "j": "markdown::ScrollDown",
      "k": "markdown::ScrollUp",
    },
  },
]
